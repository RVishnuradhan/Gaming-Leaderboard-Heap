#include <stdio.h>

int heap[10];
int size = 0;

void insert(int value)
{
    int i = size;
    heap[size++] = value;

    while (i > 0 && heap[(i - 1) / 2] < heap[i])
    {
        int temp = heap[i];
        heap[i] = heap[(i - 1) / 2];
        heap[(i - 1) / 2] = temp;

        i = (i - 1) / 2;
    }
}

int main()
{
    insert(50);
    insert(30);
    insert(70);

    printf("Top Player Score: %d\n", heap[0]);

    return 0;
}
